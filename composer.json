{
    "name": "ghostwriter/workbench",
    "description": "Local development tool for PHP",
    "license": "BSD-3-Clause",
    "type": "composer-plugin",
    "keywords": [
        "ghostwriter",
        "workbench",
        "dev"
    ],
    "authors": [
        {
            "name": "Nathanael Esayeas",
            "email": "nathanael.esayeas@protonmail.com",
            "homepage": "https://github.com/ghostwriter",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/ghostwriter/workbench",
    "support": {
        "issues": "https://github.com/ghostwriter/workbench/issues",
        "source": "https://github.com/ghostwriter/workbench",
        "rss": "https://github.com/ghostwriter/workbench/releases.atom",
        "security": "https://github.com/ghostwriter/workbench/security/advisories/new"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/ghostwriter"
        }
    ],
    "_comment": [
        "#BlackLivesMatter",
        "#FreePalestine",
        "#StandWithUkraine",
        "#StopGenocide"
    ],
    "require": {
        "php": "~8.4.0 || ~8.5.0",
        "ext-mbstring": "*",
        "composer-plugin-api": "~2.9.0",
        "composer-runtime-api": "~2.2.2",
        "composer/composer": "^2.9.5",
        "composer/semver": "^3.4.4",
        "ghostwriter/case-converter": "^2.2.0",
        "ghostwriter/clock": "^3.0.1",
        "ghostwriter/collection": "^2.0.0",
        "ghostwriter/config": "^2.0.2",
        "ghostwriter/container": "^6.0.1",
        "ghostwriter/event-dispatcher": "^6.0.2",
        "ghostwriter/filesystem": "^0.1.2",
        "ghostwriter/json": "^3.0.1",
        "ghostwriter/shell": "^0.1.4",
        "ghostwriter/uuid": "^1.0.3",
        "nikic/php-parser": "^5.7.0",
        "sebastian/diff": "^7.0.0"
    },
    "require-dev": {
        "ext-xdebug": "*",
        "ghostwriter/coding-standard": "dev-main",
        "mockery/mockery": "^1.6.12",
        "phpunit/phpunit": "^12.5.9",
        "symfony/var-dumper": "^8.0.4"
    },
    "conflict": {
        "pestphp/pest": "*"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Ghostwriter\\Workbench\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "": "tests/Fixture/",
            "Tests\\": "tests/"
        },
        "files": [
            "tests/bootstrap.php"
        ],
        "exclude-from-classmap": ["/tests/"]
    },
    "bin": [
        "bin/workbench",
        "bin/workbench.php"
    ],
    "config": {
        "allow-plugins": {
            "ghostwriter/coding-standard": true
        },
        "bump-after-update": false,
        "classmap-authoritative": false,
        "discard-changes": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.4.999"
        },
        "platform-check": true,
        "preferred-install": "dist",
        "prepend-autoloader": true,
        "process-timeout": 5000,
        "sort-packages": true,
        "use-parent-dir": false
    },
    "extra": {
        "class": "Ghostwriter\\Workbench\\Service\\Composer\\Plugin",
        "plugin-modifies-downloads": false,
        "plugin-modifies-install-path": false,
        "plugin-optional": false,
        "thanks": {
            "name": "ghostwriter/workbench",
            "url": "https://github.com/ghostwriter/workbench"
        }
    },
    "scripts": {
        "post-install-cmd": ["php bin/workbench discover"],
        "post-update-cmd": ["php bin/workbench discover"],
        "cache:clear": "rm -rf ./.cache/*",
        "check": ["@cache:clear", "tools/phar/composer validate", "@test"],
        "docker": ["@docker:build", "@docker:run"],
        "docker:build": "docker buildx build --pull --tag workspace .",
        "docker:run": "docker run -v $(PWD):/github/workspace -w=/github/workspace -e GITHUB_DEBUG=1 -e GITHUB_WORKSPACE=/github/workspace -e GITHUB_TOKEN=github-token -e SIGNING_SECRET_KEY=secret-key workspace",
        "git:submodule:update": "git submodule update --depth=1 --init --recursive --recommend-shallow --remote",
        "infection": ["@xdebug", "tools/phar/infection --min-covered-msi=0 --min-msi=0 --show-mutations --threads=max"],
        "phpbench": "tools/phar/phpbench run --report='extends:aggregate,cols:[benchmark,subject,revs,its,mem_peak,mode,rstdev]' --time-unit=milliseconds ./tests/Benchmark",
        "phpunit": ["@xdebug", "vendor/bin/phpunit --do-not-cache-result --colors=always"],
        "test": ["@phpunit", "@infection"],
        "unused": "tools/phar/composer-unused --no-interaction --ansi",
        "xdebug": "@putenv XDEBUG_MODE=coverage"
    }
}
